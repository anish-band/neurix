generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id Int @id @default(autoincrement())
  userId String
  name String
  category String
  length Float?
  rating Int? //out of 10
  startTime DateTime
  endTime DateTime?
}