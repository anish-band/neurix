generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id Int @id @default(autoincrement())
  userId String
  sessionName String
  sessionCategory String
  sessionLength Float?
  sessionRating Int? //out of 10
  startTime DateTime
  endTime DateTime?
}